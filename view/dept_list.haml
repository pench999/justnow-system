-# coding: utf-8

%div#toolbox_spacer_top
%div#toolbox
  %p 表示： 部署一覧
  - if @isadmin
    %div
      選択した部署への操作:
      %select.admin_operations#dept_operation_list
        %option{:value => 'nonedefault'} 操作を選択してください
        %option{:value => 'none', :disabled => true} -- データ削除 --
        %option{:value => 'delete_records'} 選択した部署のデータを消去
%div#toolbox_spacer_bottom
%div#maincontents
  - if @isadmin
    %form.smartadd{:name => 'create_dept', :action => '/ybz/dept/create', :method => "POST"}
      %table#deptcreate
        %tr.dept_item
          %td.td_line_head
            %div{:style => "padding-top: 3em; padding-left: 0; padding-right: 0;"}
          %td.dept_name{:style => "padding-left: 1em;"}
            名称: 
            %input.smartinput{:type => 'text', :size => 16, :name => 'name'}
          %td.td_padding_narrow
            %img{:src => "/images/1x1.gif"}
          %td.td_base{:style => "align: right;"}
            %button.icon_submit{:type => 'submit', :title => '部署を追加', :style => 'border: 0; background: transparent; padding: 0; cursor: pointer;'}
              %img{:src => '/images/adding.png', :height => 24, :width => 24, :alt => '追加'}
          %td.td_line_term
            %img{:src => "/images/1x1.gif"}
  %table#deptlist
    = partial :dept, :collection => @depts
